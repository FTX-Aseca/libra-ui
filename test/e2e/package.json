{
  "name": "libra-ui-e2e-tests",
  "version": "1.0.0",
  "description": "E2E tests for Libra UI Flutter app",
  "main": "index.js",
  "scripts": {
    "test": "wdio run ./wdio.conf.ts",
    "test:android": "echo \"Configure Android capability in wdio.conf.ts and use --suite android (not yet configured)\"",
    "test:ios": "echo \"Configure iOS capability in wdio.conf.ts and use --suite ios (not yet configured)\"",
    "android.login": "wdio run ./wdio.conf.ts --spec ./specs/login.e2e.ts"
  },
  "keywords": [
    "appium",
    "webdriverio",
    "flutter",
    "e2e"
  ],
  "author": "",
  "license": "ISC",
  "devDependencies": {
    "@types/axios": "^0.14.4",
    "@types/node": "^22.15.29",
    "@wdio/appium-service": "^9.15.0",
    "@wdio/cli": "^9.15.0",
    "@wdio/local-runner": "^9.15.0",
    "@wdio/mocha-framework": "^9.15.0",
    "@wdio/spec-reporter": "^9.15.0",
    "appium-uiautomator2-driver": "^4.2.3",
    "appium-xcuitest-driver": "^9.3.2",
    "axios": "^1.9.0",
    "dotenv": "^16.5.0",
    "typescript": "^5.8.3",
    "webdriverio": "^9.15.0"
  }
}
